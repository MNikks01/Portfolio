NEXT_PUBLIC_SITE_URL=https://nikhilmeshram.dev

# Contact form (optional). If RESEND_API_KEY is unset, the /api/contact route
# still validates + rate-limits and returns success, but does not deliver email.
RESEND_API_KEY=
# Where contact submissions are delivered (defaults to the site email).
CONTACT_TO=
# Verified Resend sender (defaults to onboarding@resend.dev for testing).
CONTACT_FROM=
